# Consistent line endings across platforms. Default to LF on checkout — shell
# scripts (the shebang breaks with a trailing CR), Go, and Godot files all want
# LF. Only Windows-native scripts stay CRLF.
* text=auto eol=lf

*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary assets — never normalize.
*.png binary

# Asset Library packaging. The Godot Asset Library installs the GitHub archive
# ZIP into a user's project, preserving paths. Keep that ZIP to the addon (plus
# LICENSE) only — everything else here is the dev project, Go CLI, CI, or docs
# and would clobber the user's project.godot or pull in irrelevant files.
# (git archive / GitHub codeload honor export-ignore.)
/cmd export-ignore
/internal export-ignore
/docs export-ignore
/scenes export-ignore
/.claude export-ignore
/.claude/** export-ignore
/.github export-ignore
/main.go export-ignore
/go.mod export-ignore
/project.godot export-ignore
/install.sh export-ignore
/install.ps1 export-ignore
/AGENTS.md export-ignore
/CLAUDE.md export-ignore
/README.md export-ignore
/README.ko.md export-ignore
/.gitignore export-ignore
/.gitattributes export-ignore
